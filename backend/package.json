{
  "name": "backend",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && node -e \"const { mkdirSync, copyFileSync } = require('node:fs'); mkdirSync('dist/db', { recursive: true }); copyFileSync('src/db/schema.sql', 'dist/db/schema.sql');\"",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^9.3.0",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.4.1",
    "fastify": "^5.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
